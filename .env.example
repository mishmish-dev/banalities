# Copy to .env and set real values for your VPS. Compose reads .env automatically.
# Local dev works without this file (defaults in compose.yaml).
POSTGRES_DB=banalities
POSTGRES_USER=banalities
POSTGRES_PASSWORD=change-me
# Public hostnames Caddy issues TLS certs for (must resolve to this VPS).
SERVER_DOMAIN=game.example.com
KEYCLOAK_DOMAIN=auth.example.com

# Keycloak admin bootstrap (first boot only) and the realm/audience the server validates.
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=change-me
KEYCLOAK_ISSUER=https://auth.example.com/realms/banalities
KEYCLOAK_AUDIENCE=banalities-server
